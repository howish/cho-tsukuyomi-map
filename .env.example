# cho-tsukuyomi-map .env — copy to .env (gitignored) and fill in.
#
# Required for the post-mirror skill's R2 backup sync.
# (See .claude/skills/post-mirror/SKILL.md for the full subcommand reference.)
#
# R2 = Cloudflare R2, S3-compatible object storage. Used to back up the
# local SQLite mirror between sessions so it survives machine resets and
# can be synced across devices.

# Cloudflare account ID — find at https://dash.cloudflare.com/?to=/:account/r2
R2_ACCOUNT_ID=

# Bucket name — create at the R2 dashboard, recommend cho-tsukuyomi-map-mirror
R2_BUCKET=

# S3-compatible API token credentials — create at R2 → "Manage R2 API Tokens"
# → "Create API token" → Edit permissions → scope to the bucket above.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Optional: override default object key (default: mirror.sqlite)
# R2_OBJECT_KEY=mirror.sqlite

# Optional: keep N rolling daily snapshots in snapshots/mirror-YYYY-MM-DD.sqlite
# (default: 0 = no snapshots, only the latest mirror.sqlite)
# R2_RETAIN_DAILY_SNAPSHOTS=7
