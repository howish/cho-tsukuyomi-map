.DS_Store
*.swp
*.log
__pycache__/

# x-api recon scratch data (timelines/rescue dumps, per-event and root)
.x-api-data/
.x-api-data*/
.scrape-data/

# scraper scratch dumps (root-level outputs from one-off runs)
# (canonical location is scripts/.scratch/; the root globs are kept so
# legacy scripts that still write to repo root don't pollute git status)
/aggregator_*.json
/aggregator_*.md
/doujintw_*.json
/doujintw_*.md
/fb_share_*.json
/fb_share_*.md
/threads_*.json
/threads_*.md
/plurk_*.json
/plurk_*.md
.name-resolver/
enrich-decisions.json
agg-decisions.json
.validation-report.json

# Per B4 (2026-06-07 structural review): scratch JSON / MD / audit dumps
# moved out of repo root. Anything under scripts/.scratch/ is one-shot
# output, never shipped.
scripts/.scratch/

# post-mirror SSOT — gitignored, R2 backup (per add-x-post-mirror)
.x-api-data/mirror.sqlite
.x-api-data/mirror.sqlite-journal
.x-api-data/mirror.sqlite-wal
.x-api-data/mirror.sqlite-shm

# R2 credentials for post-mirror sync (see .env.example)
.env
